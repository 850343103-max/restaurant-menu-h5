<view class="page">
  <view class="hero">
    <view class="brand">
      <view class="logo">{{logoText}}</view>
      <view>
        <view class="eyebrow">{{restaurantEnName}}</view>
        <view class="title">{{restaurantName}}</view>
        <view class="subtitle">原生小程序点菜</view>
      </view>
    </view>
  </view>

  <view class="notice">
    <view class="notice-title">请选择菜品</view>
    <view class="notice-text">菜品和订单与网页后台同步，提交后后台可查看和复制。</view>
  </view>

  <view class="menu-layout">
    <scroll-view class="side-tabs" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="side-tab {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view
      class="dish-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollTarget}}"
      scroll-with-animation
      bindscroll="onDishScroll"
    >
      <view wx:if="{{loading}}" class="empty">菜品加载中...</view>
      <view wx:elif="{{!groupedCategories.length}}" class="empty">暂无菜品，请联系酒店后台确认菜单。</view>

      <view class="dish-list" wx:else>
        <view
          wx:for="{{groupedCategories}}"
          wx:key="id"
          id="{{item.sectionId}}"
          data-id="{{item.id}}"
          class="category-section"
        >
          <view class="section-title">{{item.name}}</view>
          <view wx:for="{{item.dishes}}" wx:for-item="dish" wx:key="id" class="dish-card {{dish.soldOut ? 'sold' : ''}}">
            <image class="dish-img" src="{{dish.image || dish.fallbackImage}}" mode="aspectFill" />
            <view class="dish-main">
              <view class="dish-title">{{dish.name}}</view>
              <view class="dish-desc">{{dish.desc || '暂无介绍'}}</view>
              <view class="dish-bottom">
                <view class="price">￥{{dish.priceText}}</view>
                <view wx:if="{{dish.soldOut}}" class="sold-tag">售罄</view>
                <view wx:else class="qty">
                  <view class="qty-btn" data-id="{{dish.id}}" data-delta="-1" bindtap="changeQty">-</view>
                  <text>{{cart[dish.id] || 0}}</text>
                  <view class="qty-btn" data-id="{{dish.id}}" data-delta="1" bindtap="changeQty">+</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar" wx:if="{{!showOrderPanel}}">
    <view class="cart-info" bindtap="openOrderPanel">
      <view class="cart-icon-wrap">
        <view class="cart-icon">
          <view class="cart-basket"></view>
        </view>
        <view wx:if="{{cartCount}}" class="cart-badge">{{cartCount}}</view>
      </view>
      <view class="cart-copy">
        <view class="cart-total-row">
          <text class="cart-label">合计：</text>
          <text class="cart-total">￥{{cartTotal}}</text>
        </view>
        <text class="cart-hint">共{{cartCount}}道 · 点此查看</text>
      </view>
    </view>
    <button class="cart-submit {{cartCount ? '' : 'disabled'}}" bindtap="openOrderPanel">
      {{cartCount ? '确定' : '先选菜'}}
    </button>
  </view>

  <view wx:if="{{showOrderPanel}}" class="panel-mask">
    <view class="order-panel">
      <view class="panel-head">
        <view class="panel-title">提交订单</view>
        <button class="link-btn" bindtap="closeOrderPanel">收起</button>
      </view>

      <view class="cart-lines">
        <view wx:for="{{cartItems}}" wx:key="dishId" class="cart-line">
          <view>{{item.name}} <text class="muted">￥{{item.price}} x {{item.qty}}</text></view>
          <view>￥{{item.lineTotal}}</view>
        </view>
        <view class="cart-total-line">
          <text>合计</text>
          <text>￥{{cartTotal}}</text>
        </view>
      </view>

      <view class="form">
        <view class="field">
          <view class="label">客人姓名</view>
          <input value="{{form.name}}" data-key="name" bindinput="onInput" placeholder="请输入姓名" />
        </view>
        <view class="field">
          <view class="label">房号或桌号</view>
          <input value="{{form.roomNo}}" data-key="roomNo" bindinput="onInput" placeholder="例如 V222 / 8号桌" />
        </view>
        <view class="field">
          <view class="label">联系电话</view>
          <input value="{{form.phone}}" data-key="phone" bindinput="onInput" type="number" maxlength="20" placeholder="手机号" />
        </view>
        <view class="field">
          <view class="label">用餐日期</view>
          <picker mode="date" value="{{form.mealDate}}" bindchange="onDateChange">
            <view class="picker-value">{{form.mealDate || '请选择日期'}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="label">餐段</view>
          <picker mode="selector" range="{{mealPeriods}}" value="{{mealPeriodIndex}}" bindchange="onMealPeriodChange">
            <view class="picker-value">{{form.mealPeriod}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="label">用餐人数</view>
          <input value="{{form.people}}" data-key="people" bindinput="onInput" type="number" placeholder="例如 6" />
        </view>
        <view class="field">
          <view class="label">备注</view>
          <textarea value="{{form.note}}" data-key="note" bindinput="onInput" placeholder="口味、忌口、加急等" auto-height />
        </view>
      </view>

      <button class="primary-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOrder">确认提交订单</button>
    </view>
  </view>
</view>
