.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 156rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(13, 139, 114, .14), transparent 480rpx),
    linear-gradient(180deg, #edf7f3 0%, #f5f7f4 520rpx);
}

.hero {
  padding: 14rpx 0 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo {
  display: grid;
  place-items: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #0d8b72, #f4d8a9);
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
}

.eyebrow {
  color: #b37a2b;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 4rpx;
  color: #101512;
  font-size: 42rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 4rpx;
  color: #73796e;
  font-size: 24rpx;
}

.notice {
  display: grid;
  gap: 6rpx;
  margin-bottom: 20rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(179, 122, 43, .28);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .86);
}

.notice-title {
  color: #20231f;
  font-size: 30rpx;
  font-weight: 800;
}

.notice-text {
  color: #73796e;
  font-size: 24rpx;
  line-height: 1.5;
}

.menu-layout {
  display: grid;
  grid-template-columns: 152rpx 1fr;
  gap: 14rpx;
  height: calc(100vh - 360rpx);
  min-height: 620rpx;
}

.side-tabs,
.dish-scroll {
  height: 100%;
}

.side-tabs {
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .72);
  overflow: hidden;
}

.side-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 82rpx;
  padding: 18rpx 10rpx;
  border-bottom: 1rpx solid #e3e7dd;
  background: transparent;
  color: #586158;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.side-tab text {
  display: block;
  width: 100%;
  color: inherit;
  line-height: 1.25;
  white-space: normal;
  word-break: break-all;
}

.side-tab.active {
  background: #0d8b72;
  color: #fff;
  font-weight: 900;
}

.dish-list {
  display: grid;
  gap: 14rpx;
  padding-bottom: 20rpx;
}

.dish-card {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 14rpx;
  padding: 14rpx;
  border: 1rpx solid #e3e7dd;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .96);
}

.dish-card.sold {
  opacity: .52;
}

.dish-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #d7eee4, #f4d8a9);
}

.dish-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dish-title {
  color: #121712;
  font-size: 29rpx;
  font-weight: 900;
}

.dish-desc {
  margin-top: 8rpx;
  color: #73796e;
  font-size: 22rpx;
  line-height: 1.45;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.price {
  color: #bf3b34;
  font-size: 29rpx;
  font-weight: 900;
}

.sold-tag {
  color: #bf3b34;
  font-size: 26rpx;
  font-weight: 800;
}

.qty {
  display: grid;
  grid-template-columns: 48rpx 52rpx 48rpx;
  align-items: center;
  height: 52rpx;
  border: 1rpx solid #e3e7dd;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
}

.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  color: #08614f;
  font-size: 30rpx;
  font-weight: 800;
}

.qty text {
  text-align: center;
  color: #121712;
  font-size: 26rpx;
  font-weight: 800;
}

.empty {
  padding: 48rpx 24rpx;
  border: 1rpx solid #e3e7dd;
  border-radius: 14rpx;
  background: #fff;
  color: #73796e;
  text-align: center;
  font-size: 28rpx;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: grid;
  grid-template-columns: 1fr 220rpx;
  gap: 14rpx;
}

.cart-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  padding: 24rpx;
  border: 1rpx solid rgba(8, 97, 79, .14);
  border-radius: 14rpx;
  background: #fff;
  box-shadow: 0 16rpx 40rpx rgba(25, 40, 31, .14);
  color: #20231f;
  font-size: 28rpx;
}

.cart-total {
  color: #bf3b34;
  font-weight: 900;
}

.cart-submit {
  display: grid;
  place-items: center;
  border-radius: 14rpx;
  background: #08614f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 40rpx rgba(25, 40, 31, .14);
}

.cart-submit.disabled {
  background: #7b8580;
}

.panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(13, 20, 17, .2);
}

.order-panel {
  width: 100%;
  max-height: 88vh;
  overflow: auto;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.panel-title {
  color: #20231f;
  font-size: 38rpx;
  font-weight: 900;
}

.link-btn {
  padding: 14rpx 20rpx;
  border: 1rpx solid #e3e7dd;
  border-radius: 12rpx;
  color: #20231f;
  font-size: 26rpx;
}

.cart-lines {
  margin-top: 16rpx;
  border-bottom: 1rpx solid #e3e7dd;
}

.cart-line,
.cart-total-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  color: #20231f;
  font-size: 27rpx;
}

.cart-total-line {
  color: #121712;
  font-weight: 900;
}

.muted {
  color: #73796e;
  font-size: 23rpx;
}

.form {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.field {
  display: grid;
  gap: 8rpx;
}

.label {
  color: #73796e;
  font-size: 24rpx;
}

input,
textarea,
.picker-value {
  width: 100%;
  min-height: 84rpx;
  padding: 22rpx;
  border: 1rpx solid #e3e7dd;
  border-radius: 14rpx;
  background: #fff;
  color: #20231f;
  font-size: 28rpx;
}

textarea {
  min-height: 150rpx;
  line-height: 1.5;
}

.primary-btn {
  display: grid;
  place-items: center;
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  border-radius: 14rpx;
  background: #0d8b72;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
}
